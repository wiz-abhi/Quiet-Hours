# === Quiet Hours — environment configuration ===
# Copy this file to `.env` and fill in the values you have.
# Slack credentials are required to run the app. PagerDuty and Anthropic
# keys are OPTIONAL — the code ships with mock/fallback behavior so the
# demo works even without them.

# --- Slack (required) ---
# Bot token (xoxb-...), from OAuth & Permissions.
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-level token (xapp-...) with connections:write, for Socket Mode.
SLACK_APP_TOKEN=xapp-your-app-token
# Signing secret from Basic Information.
SLACK_SIGNING_SECRET=your-signing-secret

# --- Anthropic (optional; falls back to templated copy if unset) ---
ANTHROPIC_API_KEY=sk-ant-your-key
# Model used for drafting handoff notes. Defaults to claude-sonnet-5.
ANTHROPIC_MODEL=claude-sonnet-5

# --- PagerDuty (optional; MCP client returns mock data if unset) ---
PAGERDUTY_TOKEN=your-pagerduty-token
PAGERDUTY_SCHEDULE_ID=your-schedule-id

# --- Quiet Hours tuning ---
# Comma-separated Slack channel IDs to watch, e.g. C0123ABC,C0456DEF
QH_WATCHED_CHANNELS=
# Hours to offset UTC to compute the responder's local hour, e.g. -5 for US Eastern.
QH_TIMEZONE_OFFSET_HOURS=0
